{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkNeat",
  "version": "0.1.0",
  "identifier": "app.workneat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WorkNeat",
        "width": 1240,
        "height": 780,
        "minWidth": 960,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "icon": ["icons/icon.icns"],
    "targets": ["dmg", "app"],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-"
    }
  }
}
